#!/usr/bin/env bash
# meda-fe — MEDA Frontend CLI. Scans a repo, decides new-vs-existing, installs skills, generates an
# assessment report. The CLI does the scanning/reporting (no AI needed); the AI does the development
# afterwards using the installed skills.
#
# Commands:
#   meda-fe scan [--path DIR]      Scan the repo: empty → setup; existing → assessment report
#   meda-fe setup [--path DIR]     Interactive: install skills + prepare a (new) frontend repo
#   meda-fe assess [--path DIR]    Scan an existing repo and write ASSESSMENT.md
#   meda-fe install [--path DIR]   Just install the skills (no scan)
#   meda-fe verify [--path DIR]    Verify skills are installed
#   meda-fe list                   List available skills
#   meda-fe version | help

set -euo pipefail

resolve_self() {
  local src="${BASH_SOURCE[0]}"
  while [ -h "$src" ]; do local dir; dir="$(cd -P "$(dirname "$src")" && pwd)"; src="$(readlink "$src")"; [[ $src != /* ]] && src="$dir/$src"; done
  cd -P "$(dirname "$src")" && pwd
}
BIN_DIR="$(resolve_self)"; ROOT_DIR="$(cd "$BIN_DIR/.." && pwd)"
SRC_SKILLS="$ROOT_DIR/skills"; SRC_CLAUDE="$ROOT_DIR/templates/CLAUDE.md"
VERSION="$(cat "$ROOT_DIR/VERSION" 2>/dev/null || echo dev)"
g=$'\033[0;32m'; y=$'\033[0;33m'; r=$'\033[0;31m'; b=$'\033[0;34m'; off=$'\033[0m'
ok(){ printf "${g}✓${off} %s\n" "$*"; }; warn(){ printf "${y}!${off} %s\n" "$*"; }; err(){ printf "${r}✗${off} %s\n" "$*" >&2; }; info(){ printf "%s\n" "$*"; }
TARGET="$(pwd)"
REPORT_ONLY=0
parse_path(){ while [ $# -gt 0 ]; do case "$1" in --path) TARGET="$2"; shift 2;; --report-only) REPORT_ONLY=1; shift;; *) shift;; esac; done; }
MARK_START="<!-- MEDA FE SKILLS START -->"; MARK_END="<!-- MEDA FE SKILLS END -->"

# ---------- detection ----------
is_empty_repo() {
  # "empty" = no source files (ignores .git, hidden config, README)
  local count
  count="$(find "$TARGET" -maxdepth 2 -type f \
    ! -path '*/.git/*' ! -name '.*' ! -name 'README*' ! -name 'LICENSE*' 2>/dev/null | wc -l | tr -d ' ')"
  [ "$count" -eq 0 ]
}
has_file(){ [ -f "$TARGET/$1" ]; }
detect(){ # echoes a key if found (each check tolerant to "not found")
  local pj="$TARGET/package.json"
  [ -f "$pj" ] || { echo "no-package-json"; return 0; }
  echo "has-package-json"
  grep -q '"next"' "$pj" && echo "has-next" || true
  grep -q '"react"' "$pj" && echo "has-react" || true
  grep -q '"typescript"' "$pj" && echo "has-ts" || true
  grep -q '"tailwindcss"' "$pj" && echo "has-tailwind" || true
  grep -q '"zustand"' "$pj" && echo "has-zustand" || true
  grep -q '"@reduxjs/toolkit"' "$pj" && echo "has-redux" || true
  grep -q '"@tanstack/react-query"' "$pj" && echo "has-tanstack" || true
  grep -q '"swr"' "$pj" && echo "has-swr" || true
  [ -f "$TARGET/pnpm-lock.yaml" ] && echo "has-pnpm" || true
  [ -f "$TARGET/package-lock.json" ] && echo "has-npm" || true
  [ -f "$TARGET/yarn.lock" ] && echo "has-yarn" || true
  return 0
}

install_skills() {
  mkdir -p "$TARGET/.claude/skills" "$TARGET/.gemini/skills"
  cp -R "$SRC_SKILLS/." "$TARGET/.claude/skills/"
  cp -R "$SRC_SKILLS/." "$TARGET/.gemini/skills/"
  if [ ! -f "$TARGET/CLAUDE.md" ]; then cp "$SRC_CLAUDE" "$TARGET/CLAUDE.md";
  elif ! grep -q "$MARK_START" "$TARGET/CLAUDE.md" 2>/dev/null; then
    { printf "\n%s\n" "$MARK_START"; cat "$SRC_CLAUDE"; printf "%s\n" "$MARK_END"; } >> "$TARGET/CLAUDE.md"; fi
  ok "Skills installed: .claude/skills + .gemini/skills ($(ls "$SRC_SKILLS" | wc -l | tr -d ' ') skills)"
}

# ---------- commands ----------
cmd_scan() {
  parse_path "$@"
  info "${b}Scanning:${off} $TARGET"
  if is_empty_repo; then
    ok "Empty repo detected → this is a NEW frontend project."
    if [ "$REPORT_ONLY" = "1" ]; then
      warn "Empty repo + --report-only: nothing to report. Run 'meda-fe setup' to scaffold instead."
      return 0
    fi
    info "Running interactive setup..."
    cmd_new --path "$TARGET"
  else
    ok "Existing code detected → generating assessment report."
    local fwd=""; [ "$REPORT_ONLY" = "1" ] && fwd="--report-only"
    cmd_assess --path "$TARGET" $fwd
  fi
}

cmd_new() {
  parse_path "$@"
  info "${b}MEDA Frontend setup (new project)${off}"
  info "Each question has a short 'why' so you choose with context. Press Enter for the [default]."
  info ""

  info "${b}1) Project type${off}"
  info "   Why: it shapes how much structure you need. full-app = dashboards/portals with auth and"
  info "   private routes; landing = marketing site; lib = an internal component library."
  read -rp "   full-app / landing / lib [full-app]: " p_type; p_type=${p_type:-full-app}
  info ""

  info "${b}2) Folder architecture${off}"
  info "   Why: how you organize code as it grows. Three options:"
  info "     by-type      → components/ hooks/ services/ (simple; good for small apps)"
  info "     by-feature   → features/<name>/ each with its own components+hooks (balanced; RECOMMENDED)"
  info "     screaming    → modules/<domain>/ everything per business domain (large apps/teams)"
  read -rp "   by-type / by-feature / screaming [by-feature]: " p_arch; p_arch=${p_arch:-by-feature}
  info ""

  info "${b}3) State management${off}"
  info "   Why: where shared UI state lives. Zustand = light, simple (most apps). Redux Toolkit ="
  info "   heavier, for complex global state and many cross-feature slices. none = local state only."
  read -rp "   zustand / redux / none [zustand]: " p_state; p_state=${p_state:-zustand}
  info ""

  info "${b}4) Data fetching${off}"
  info "   Why: how you load server data. tanstack = TanStack Query (cache, retries, recommended for"
  info "   client data). rsc = Server Components only (server-rendered). swr = lighter alternative."
  read -rp "   tanstack / rsc / swr [tanstack]: " p_data; p_data=${p_data:-tanstack}
  info ""

  info "${b}5) MEDA UI base components${off}"
  info "   Why: copies the Binance-style components (Button, Input, Card, Table...) into your repo so"
  info "   the look is consistent from day one. You own the code (shadcn-style)."
  read -rp "   include MEDA UI? y/n [y]: " p_ui; p_ui=${p_ui:-y}
  info ""

  info "${b}6) Authentication${off}"
  info "   Why: if your app has private routes, this scaffolds session handling + a route guard."
  info "   Say no for public sites or if auth is handled elsewhere."
  read -rp "   add auth + route guard? y/n [n]: " p_auth; p_auth=${p_auth:-n}
  info ""

  info "${b}7) Connect to MEDA Java APIs${off}"
  info "   Why: sets up the API client that handles MEDA's APIResponse convention (HTTP 200 with"
  info "   status:ERROR) + Zod for validation. Say yes if this app talks to MEDA backend services."
  read -rp "   set up the API client? y/n [y]: " p_api; p_api=${p_api:-y}
  info ""

  info "${b}8) Generate now${off}"
  info "   Why: yes = the CLI runs create-next-app + installs everything, leaving it ready for"
  info "   'pnpm dev'. no = only records your choices so you (or the AI) generate later."
  read -rp "   generate the Next.js project now? y/n [y]: " p_gen; p_gen=${p_gen:-y}
  info ""

  # Summary before executing (CLI best practice: confirm the plan)
  info "${b}Summary of your choices:${off}"
  info "   type=$p_type  arch=$p_arch  state=$p_state  data=$p_data  ui=$p_ui  auth=$p_auth  api=$p_api  generate=$p_gen"
  info ""

  # Check prerequisites
  if [ "$p_gen" = "y" ]; then
    command -v pnpm >/dev/null 2>&1 || { err "pnpm not found. Install it first: npm i -g pnpm  (then re-run)"; exit 1; }
    command -v node >/dev/null 2>&1 || { err "node not found. Install Node.js 20.9+ first."; exit 1; }
  fi

  # Helper to write the choices file (called at the right moment depending on the path)
  write_setup_md() {
    cat > "$TARGET/MEDA-FE-SETUP.md" << EOF
# MEDA Frontend — chosen setup

- Project type: **$p_type**
- Folder architecture: **$p_arch**
- State management: **$p_state**
- Data fetching: **$p_data**
- MEDA UI base components: **$p_ui**
- Authentication: **$p_auth**
- Connect to MEDA Java APIs: **$p_api**
- Package manager: **pnpm** · Framework: **Next.js 16 (App Router)** · Language: **TypeScript**

## Folder architecture chosen: $p_arch
$(arch_explainer)
EOF
  }

  arch_explainer() {
    case "$p_arch" in
      by-type) echo "Organize by technical type: src/components, src/hooks, src/services, src/stores. Simple, good for small apps.";;
      screaming) echo "Organize by business domain: src/modules/<domain>/ (each with components, hooks, services). Best for large apps/teams.";;
      *) echo "Organize by feature: src/features/<name>/ (each with components, hooks, api, types) + shared in src/components, src/lib. Balanced default.";;
    esac
  }

  # Create the folder skeleton for the chosen architecture
  scaffold_arch() {
    local base="$TARGET/src"
    mkdir -p "$base/lib" "$base/types"
    case "$p_arch" in
      by-type)   mkdir -p "$base/components" "$base/hooks" "$base/services" "$base/stores";;
      screaming) mkdir -p "$base/modules" "$base/components/ui" "$base/stores";;
      *)         mkdir -p "$base/features" "$base/components/ui" "$base/components/shared" "$base/hooks" "$base/lib/api" "$base/stores";;
    esac
  }

  if [ "$p_gen" != "y" ]; then
    write_setup_md
    install_skills
    ok "Setup recorded in MEDA-FE-SETUP.md (project NOT generated — you chose no)."
    info "To generate later: open the folder in your agent and type '/meda-fe-new use MEDA-FE-SETUP.md'."
    return 0
  fi

  # --- Generate the real Next.js project ---
  local proj; proj="$(basename "$TARGET")"
  info ""
  info "${b}Generating Next.js project '$proj' (this downloads packages, takes a minute)...${off}"

  # create-next-app needs an empty dir; it creates files in place with "."
  # --yes uses defaults: TS + Tailwind + ESLint + App Router + Turbopack + src/ + @/* alias
  # --yes uses defaults; --src-dir forces app/ inside src/ for a consistent structure
  ( cd "$TARGET" && pnpm create next-app@latest . --yes --use-pnpm --src-dir ) || { err "create-next-app failed"; exit 1; }
  ok "Next.js base created."
  scaffold_arch
  ok "Folder architecture scaffolded: $p_arch"

  # Ensure the @/* alias points to src/* (create-next-app with src dir sets ./* — fix it so @/lib works)
  if [ -d "$TARGET/src" ] && [ -f "$TARGET/tsconfig.json" ]; then
    if grep -q '"@/\*": \["\./\*"\]' "$TARGET/tsconfig.json"; then
      sed -i.bak 's|"@/\*": \["\./\*"\]|"@/*": ["./src/*"]|' "$TARGET/tsconfig.json" && rm -f "$TARGET/tsconfig.json.bak"
      ok "Path alias @/* fixed to ./src/*"
    fi
  fi
  write_setup_md

  # Extra dependencies per choices
  local deps=""
  case "$p_state" in zustand) deps="$deps zustand";; redux) deps="$deps @reduxjs/toolkit react-redux";; esac
  case "$p_data" in tanstack) deps="$deps @tanstack/react-query";; swr) deps="$deps swr";; esac
  [ "$p_api" = "y" ] && deps="$deps zod"          # forms/validation for API payloads
  [ "$p_ui" = "y" ] && deps="$deps clsx tailwind-merge"
  if [ -n "$deps" ]; then
    info "Installing extra deps:$deps"
    # pnpm may exit non-zero on build-script warnings even when deps were added; don't treat that as fatal.
    ( cd "$TARGET" && pnpm add $deps ) || true
    info "Extra deps processed. If pnpm mentions 'approve-builds', it's optional (sharp etc.)."
  fi

  # MEDA UI components
  if [ "$p_ui" = "y" ]; then
    cmd_add all --path "$TARGET" >/dev/null 2>&1 && ok "MEDA UI components added (components/ui/)."
  fi

  # Install skills + bootstrap
  install_skills

  ok "Project '$proj' is ready."
  info ""
  info "${b}Run it:${off}"
  info "  cd "$TARGET" && pnpm dev"
  info ""
  info "${b}Then develop:${off} open the folder in Cursor/Claude Code and use /meda-fe-* (or natural language)."
  [ "$p_ui" = "y" ] && info "MEDA UI: import './styles/meda-tokens.css' in your root layout and add the preset to tailwind config."
}

cmd_assess() {
  parse_path "$@"
  local report="$TARGET/ASSESSMENT.md"
  local d; d="$(detect)"
  info "${b}Assessing existing repo...${off}"
  [ "$REPORT_ONLY" = "1" ] && info "(report-only mode: will NOT install skills or modify the repo)"

  # Resolve detected facts
  has(){ echo "$d" | grep -q "^$1$"; }  # used in conditionals, safe
  fw="Unknown"; has has-next && fw="Next.js"
  lang="JavaScript"; has has-ts && lang="TypeScript"
  pm="unknown"; has has-pnpm && pm="pnpm"; has has-npm && pm="npm"; has has-yarn && pm="yarn"
  state="none detected"; has has-zustand && state="Zustand"; has has-redux && state="Redux Toolkit"
  has has-zustand && has has-redux && state="Zustand AND Redux (⚠ both present)"
  data="none detected"; has has-tanstack && data="TanStack Query"; has has-swr && data="SWR"

  if [ "$REPORT_ONLY" = "1" ]; then
    info "Skipping skill install (--report-only)."
  else
    install_skills
  fi

  {
    echo "# Frontend Assessment — $(basename "$TARGET")"
    echo ""
    echo "_Generated by meda-fe v$VERSION on $(date +%Y-%m-%d). Static scan against MEDA frontend standards._"
    echo ""
    echo "## How this project is built (detected)"
    echo "| Aspect | Detected | MEDA standard | Status |"
    echo "|---|---|---|---|"
    echo "| Framework | $fw | Next.js 16 App Router | $(has has-next && echo '✓' || echo '✗ review') |"
    echo "| Language | $lang | TypeScript | $(has has-ts && echo '✓' || echo '✗ should be TS') |"
    echo "| Package manager | $pm | pnpm | $([ "$pm" = pnpm ] && echo '✓' || echo '! prefer pnpm') |"
    echo "| Styling | $(has has-tailwind && echo Tailwind || echo 'none detected') | Tailwind + tokens | $(has has-tailwind && echo '✓' || echo '! consider Tailwind') |"
    echo "| State management | $state | Zustand (default) / Redux (complex) | $(echo "$state" | grep -q 'both' && echo '✗ pick one' || echo '✓/—') |"
    echo "| Data fetching | $data | TanStack + RSC (recommended) | — |"
    echo ""
    echo "## Folder structure"
    echo '```'
    find "$TARGET" -maxdepth 2 -type d ! -path '*/.git/*' ! -path '*/node_modules/*' ! -path '*/.next/*' 2>/dev/null | sed "s|$TARGET|.|" | head -30
    echo '```'
    echo "_Compare against \`fe-project-structure\` (app/, components/ui, features/, lib/api, stores/)._"
    echo ""
    echo "## Security scan (static heuristics — confirm with /meda-fe-review)"
    echo "| Check | Finding |"
    echo "|---|---|"
    # heuristic grep-based checks (best-effort, no AI)
    local secrets ls_tokens any_count dnghtml nextpublic
    # robust counter: never aborts under set -e
    count_match(){ local n; n="$( { grep -rEl "$1" "$TARGET/src" "$TARGET/app" 2>/dev/null || true; } | wc -l | tr -d " ")"; echo "${n:-0}"; }
    secrets="$(count_match "(apikey|api_key|api-key|secret|password|sk_live|sk_test)")"
    ls_tokens="$(count_match "localStorage.*[Tt]oken")"
    any_count="$(count_match ":[[:space:]]*any([[:space:]]|;|,|\)|>)")"
    dnghtml="$(count_match "dangerouslySetInnerHTML")"
    nextpublic="$(count_match "NEXT_PUBLIC_.*(SECRET|KEY|TOKEN)")"
    echo "| Hardcoded secrets (key/secret/password literals) | ${secrets:-0} file(s) — P0 if >0 |"
    echo "| Tokens in localStorage | ${ls_tokens:-0} file(s) — P0 if >0 |"
    echo "| Secrets in NEXT_PUBLIC_* | ${nextpublic:-0} file(s) — P0 if >0 |"
    echo "| \`dangerouslySetInnerHTML\` usage | ${dnghtml:-0} file(s) — review for XSS |"
    echo "| \`: any\` occurrences (TS) | ${any_count:-0} — reduce; \`any\` is prohibited |"
    echo ""
    echo "> These are best-effort static checks. For a real review, open the repo in your agent and"
    echo "> run \`/meda-fe-review\` (full standards) or \`/meda-fe-dev audit security\`."
    echo ""
    if [ "$pm" != "pnpm" ] && [ "$pm" != "unknown" ]; then
      echo "## Migrating to pnpm (you're using $pm)"
      echo "MEDA standardizes on **pnpm** (faster, disk-efficient, strict dependency resolution). Migrating"
      echo "is safe and reversible. Steps:"
      echo ""
      echo '```bash'
      echo "# 1. Install pnpm if you don't have it"
      echo "npm install -g pnpm"
      echo ""
      echo "# 2. Remove the old lockfile and node_modules"
      if [ "$pm" = "yarn" ]; then echo "rm -rf node_modules yarn.lock"; else echo "rm -rf node_modules package-lock.json"; fi
      echo ""
      echo "# 3. Let pnpm import and install from package.json"
      echo "pnpm install"
      echo ""
      echo "# 4. Update your scripts/CI/Docker to use 'pnpm' instead of $pm"
      echo "#    e.g. '$pm run build' -> 'pnpm build',  '$pm install' -> 'pnpm install'"
      echo '```'
      echo ""
      echo "> Note: this changes how dependencies are installed, not your code. Commit the new"
      echo "> \`pnpm-lock.yaml\` and remove the old lockfile from git. Verify the app builds before pushing."
      echo ""
    fi
    echo "## What to do next"
    echo "1. Review this assessment with the team."
    echo "2. To align the repo to standards, open it in your agent and run \`/meda-fe-dev\` and ask to"
    echo "   unify structure / state / API client as needed."
    echo "3. To develop, use the \`/meda-fe-*\` commands (skills are now installed in .claude/skills)."
  } > "$report"

  ok "Report written: ASSESSMENT.md"
  info "Open it to see how the project is built and what diverges from MEDA standards."
  info "Then develop with the /meda-fe-* commands in your agent."
}

cmd_install(){ parse_path "$@"; install_skills; }
cmd_verify(){ parse_path "$@"; local e; e="$(ls "$SRC_SKILLS" | wc -l | tr -d ' ')";
  for x in .claude/skills .gemini/skills; do
    if [ -d "$TARGET/$x" ]; then local n; n="$(find "$TARGET/$x" -name SKILL.md|wc -l|tr -d ' ')"; [ "$n" -ge "$e" ] && ok "$x ($n)" || warn "$x has $n of $e"; else err "$x missing"; fi; done; }
cmd_list(){ info "${b}Frontend skills (v$VERSION):${off}"; for s in "$SRC_SKILLS"/*/; do printf "  ${g}%s${off}\n" "$(basename "$s")"; done; }


cmd_add() {
  # meda-fe add <component> [--path DIR]   — copy a MEDA UI component into the repo (shadcn-style)
  local comp=""
  while [ $# -gt 0 ]; do case "$1" in --path) TARGET="$2"; shift 2;; *) comp="$1"; shift;; esac; done
  local UI_SRC="$ROOT_DIR/ui"
  [ -d "$UI_SRC" ] || { err "UI source not found"; exit 1; }

  # Detect base dir: if the project uses src/, install under src/; else at root.
  local BASE="$TARGET"
  [ -d "$TARGET/src" ] && BASE="$TARGET/src"

  mkdir -p "$BASE/components/ui" "$BASE/lib" "$BASE/lib/utils" "$BASE/lib/api" "$BASE/styles"
  [ -f "$BASE/lib/cn.ts" ] || cp "$UI_SRC/lib/cn.ts" "$BASE/lib/cn.ts"
  # Copy the utility layer (format, validators, mask, API client) — what MEDA apps reuse
  cp "$UI_SRC"/lib/utils/*.ts "$BASE/lib/utils/" 2>/dev/null
  cp "$UI_SRC"/lib/api/*.ts "$BASE/lib/api/" 2>/dev/null
  [ -f "$BASE/lib/index.ts" ] || cp "$UI_SRC/lib/index.ts" "$BASE/lib/index.ts"
  [ -f "$BASE/styles/meda-tokens.css" ] || cp "$UI_SRC/tokens/tokens.css" "$BASE/styles/meda-tokens.css"
  # tailwind preset goes at project root (where tailwind.config lives)
  [ -f "$TARGET/meda-tailwind-preset.js" ] || cp "$UI_SRC/tokens/tailwind-preset.js" "$TARGET/meda-tailwind-preset.js"

  local rel="src/"; [ "$BASE" = "$TARGET" ] && rel=""
  if [ -z "$comp" ] || [ "$comp" = "all" ]; then
    cp "$UI_SRC"/components/*.tsx "$UI_SRC"/components/index.ts "$BASE/components/ui/" 2>/dev/null
    ok "All MEDA UI components copied to ${rel}components/ui/"
  else
    local f="$UI_SRC/components/$comp.tsx"
    [ -f "$f" ] || { err "Unknown component: $comp"; info "Available:"; ls "$UI_SRC/components" | sed 's/.tsx//;s/index//' | grep -v '^$' | sed 's/^/  /'; exit 1; }
    cp "$f" "$BASE/components/ui/"
    ok "Component '$comp' copied to ${rel}components/ui/$comp.tsx"
  fi
  info ""
  info "Remember: import the preset in tailwind.config and the tokens CSS in your root layout."
  info "  tailwind:  presets: [require('./meda-tailwind-preset')]"
  info "  layout:    import '@/styles/meda-tokens.css'"
}

usage(){ cat <<U
${b}meda-fe v$VERSION${off} — MEDA Frontend CLI

PRIMARY COMMANDS (explicit — use these when you know your case):
  meda-fe new                   NEW project: interactive setup + generates the Next.js app
  meda-fe assess [--report-only]  EXISTING repo: writes ASSESSMENT.md (+ installs skills)
                                  --report-only: report ONLY, don't install or modify anything
  meda-fe add <component|all>   Copy a MEDA UI component into the repo

CONVENIENCE:
  meda-fe scan                  Don't know what you have? Detects empty-vs-existing and routes to
                                'new' or 'assess'. Optional shortcut; prints what it decided.

UTILITY:
  meda-fe install               Install skills only (no scan/setup)
  meda-fe verify                Verify skills are installed
  meda-fe list                  List available skills
  meda-fe version | help

TYPICAL USE:
  # New project (you know it's new):
  mkdir my-app && cd my-app && meda-fe new
  # Existing repo (develop in it):
  cd my-repo && meda-fe assess
  # Just review, touch nothing:
  cd some-repo && meda-fe assess --report-only
U
}

case "${1:-help}" in
  scan) shift; cmd_scan "$@";;
  new) shift; cmd_new "$@";;
  setup) shift; cmd_new "$@";;   # alias of new (backward compat)
  assess) shift; cmd_assess "$@";;
  add) shift; cmd_add "$@";;
  install) shift; cmd_install "$@";;
  verify) shift; cmd_verify "$@";;
  list) shift; cmd_list "$@";;
  version|-v|--version) echo "meda-fe v$VERSION";;
  help|-h|--help|*) usage;;
esac
